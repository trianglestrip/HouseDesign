{
  "scale": {
    "pixelsPerMeter": 40,
    "minZoom": 0.1,
    "maxZoom": 20,
    "zoomSpeed": 0.001,
    "comment": "1米 = 40像素，即1cm = 2px。适合一般住宅尺寸(10m x 10m)"
  },
  "canvas": {
    "defaultWidth": 10000,
    "defaultHeight": 10000,
    "comment": "默认画布 10m x 10m (10000mm)，适合一般住宅房间"
  },
  "wall": {
    "fillColor": "#d4c4b0",
    "strokeColor": "#8b7355",
    "strokeWidth": 2,
    "opacity": 0.9,
    "defaultThickness": 200,
    "defaultType": "solid",
    "comment": "默认墙厚 200mm，类型：solid(实线)/dashed(虚线)/double(双线)"
  },
  "endpoint": {
    "radius": 6,
    "fillColor": "#409EFF",
    "strokeColor": "#fff",
    "strokeWidth": 2,
    "opacity": 0.8,
    "hoverOpacity": 1.0
  },
  "snapIndicator": {
    "radius": 8,
    "fillColor": "#409EFF",
    "strokeColor": "#fff",
    "strokeWidth": 2,
    "opacity": 0.8,
    "angleSnapThreshold": 15,
    "comment": "按住Shift时，角度在15度范围内吸附到水平/垂直"
  },
  "previewLine": {
    "strokeColor": "#409EFF",
    "strokeWidth": 2,
    "strokeDashArray": [8, 4],
    "opacity": 0.7,
    "showCenterLine": true,
    "comment": "绘制预览线，showCenterLine表示是否显示中心线"
  },
  "dimension": {
    "enabled": true,
    "lineColor": "#ff6b00",
    "textColor": "#ff6b00",
    "backgroundColor": "rgba(255, 255, 255, 0.9)",
    "fontSize": 12,
    "offsetDistance": 30,
    "comment": "绘制时的尺寸标注，enabled控制是否显示"
  },
  "grid": {
    "size": 20,
    "color": "#e0e0e0",
    "majorColor": "#b0b0b0",
    "strokeWidth": 0.5,
    "majorStrokeWidth": 1,
    "majorInterval": 5,
    "comment": "每5格用更深的颜色"
  },
  "ruler": {
    "width": 30,
    "backgroundColor": "#f5f5f5",
    "textColor": "#333",
    "lineColor": "#999",
    "fontSize": 10,
    "unit": "cm",
    "comment": "左侧和顶部的刻度尺，单位：厘米"
  },
  "door": {
    "fillColor": "#c4a35a",
    "strokeColor": "#333",
    "strokeWidth": 1
  },
  "window": {
    "fillColor": "#87ceeb",
    "strokeColor": "#333",
    "strokeWidth": 1
  },
  "furniture": {
    "fillColor": "#A5D6A7",
    "strokeColor": "#333",
    "strokeWidth": 1
  }
}
