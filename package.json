{
  "name": "housedesign-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Industrial-grade CAD/BIM editor for house design",
  "scripts": {
    "dev": "npm run dev --workspace=@housedesign/ui",
    "build:core": "npm run build --workspace=@housedesign/core",
    "build:ui": "npm run build --workspace=@housedesign/ui",
    "build": "npm run build:core && npm run build:ui",
    "test": "npm run test --workspace=@housedesign/ui",
    "test:ui": "npm run test:ui --workspace=@housedesign/ui"
  },
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "vue": "^3.4.0",
    "pinia": "^2.1.7",
    "fabric": "^5.3.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.11.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "vite": "^5.0.0",
    "vue-tsc": "^1.8.27",
    "@playwright/test": "^1.41.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
